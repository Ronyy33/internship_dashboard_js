<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Internship Portal</title>


  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

  <link rel="stylesheet" href="/static/css/style.css">

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

 
  <nav class="navbar navbar-expand-lg sticky-top">
    <div class="container">
      <a href="/" class="navbar-brand">
        <img
          alt="College Logo"
          src="/static/assets/logo.png"
          class="institution-emblem"
        >
        Internship Portal
      </a>
      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#topNavCollapse"
      >
        <span class="navbar-toggler-icon"></span>
      </button>
      <div id="topNavCollapse" class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <%
            var activePath = '';
            if (locals.request) { activePath = locals.request.path; }
            var isSignedIn = (locals.user != null);
            var isProfessor = isSignedIn && (locals.user.role === 'faculty');
          %>
          <li class="nav-item">
            <a
              href="/"
              class="nav-link <% if (activePath === '/') { %>active<% } %>"
            >
              <i class="bi bi-house-door me-1"></i>Home
            </a>
          </li>
          <% if (isSignedIn && isProfessor) { %>
            <li class="nav-item">
              <a
                href="/applications"
                class="nav-link <% if (activePath === '/applications') { %>active<% } %>"
              >
                <i class="bi bi-card-list me-1"></i>Applications
              </a>
            </li>
            <li class="nav-item">
              <a
                href="/dashboard"
                class="nav-link <% if (activePath === '/dashboard') { %>active<% } %>"
              >
                <i class="bi bi-graph-up me-1"></i>Dashboard
              </a>
            </li>
            <li class="nav-item">
              <a
                href="/post"
                class="nav-link <% if (activePath === '/post') { %>active<% } %>"
              >
                <i class="bi bi-plus-square me-1"></i>Post Internship
              </a>
            </li>
          <% } %>
          <% if (isSignedIn) { %>
            <li class="nav-item ms-lg-3">
              <a
                href="/logout"
                class="nav-link btn btn-outline-danger px-3 py-1 mt-1 text-danger border-danger"
              >
                <i class="bi bi-box-arrow-right me-1"></i>Logout (<%= locals.user.name %>)
              </a>
            </li>
          <% } else { %>
            <li class="nav-item ms-lg-3">
              <a
                href="/login"
                class="nav-link btn btn-primary text-white px-3 py-1 mt-1"
              >
                <i class="bi bi-box-arrow-in-right me-1"></i>Login
              </a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>


  <div class="container mt-4 mb-5 fade-slide-in">
    <%
      var hasGoodNews = (locals.successMsg != null);
      var hasBadNews = (locals.errorMsg != null);
      var hasCaution = (locals.warningMsg != null);
    %>
    <% if (hasGoodNews) { %>
      <div class="alert alert-success mt-2"><%= locals.successMsg %></div>
    <% } %>
    <% if (hasBadNews) { %>
      <div class="alert alert-danger mt-2"><%= locals.errorMsg %></div>
    <% } %>
    <% if (hasCaution) { %>
      <div class="alert alert-warning mt-2"><%= locals.warningMsg %></div>
    <% } %>

    <%- body %>
  </div>


  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
