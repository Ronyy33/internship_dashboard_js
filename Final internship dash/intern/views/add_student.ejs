<div class="row justify-content-center mb-5">
  <div class="col-md-8">
    <div class="content-banner d-flex justify-content-between align-items-center mb-4">
      <h2 class="primary-title mb-0">Enroll a New Student</h2>
    </div>

    <div class="card p-4">
      <form method="POST" action="/add_student">
        <div class="row mb-3">
          <%
            var pupilInputs = [
              { caption: 'Full Name', key: 'name', kind: 'text', hint: 'John Doe' },
              { caption: 'Email Address', key: 'email', kind: 'email', hint: 'john@example.com' }
            ];
            for (var e = 0; e < pupilInputs.length; e += 1) {
              var inp = pupilInputs[e];
          %>
          <div class="col-md-6">
            <label><%= inp.caption %></label>
            <input
              class="form-control"
              type="<%= inp.kind %>"
              name="<%= inp.key %>"
              placeholder="<%= inp.hint %>"
              required
            >
          </div>
          <% } %>
        </div>

        <div class="row mb-4">
          <div class="col-md-6">
            <label>Branch</label>
            <input
              class="form-control"
              type="text"
              name="branch"
              placeholder="e.g. Computer Science"
              required
            >
          </div>
          <div class="col-md-6">
            <label>Year</label>
            <select class="form-select" name="year">
              <%
                var yearOptions = [
                  { code: 'SE', display: 'SE (Second Year)' },
                  { code: 'TE', display: 'TE (Third Year)' },
                  { code: 'BE', display: 'BE (Final Year)' }
                ];
                for (var y = 0; y < yearOptions.length; y += 1) {
                  var opt = yearOptions[y];
              %>
                <option value="<%= opt.code %>"><%= opt.display %></option>
              <% } %>
            </select>
          </div>
        </div>

        <button type="submit" class="btn btn-primary w-100">
          <i class="bi bi-person-plus me-2"></i>Enroll Student
        </button>
      </form>
    </div>
  </div>
</div>

<div class="row justify-content-center">
  <div class="col-md-10">
    <h4 class="mb-4">Enrolled Students</h4>
    <div class="card p-4">
      <%
        var pupilRecords = (students != null) ? students : [];
        var hasPupils = (pupilRecords.length > 0);
      %>
      <% if (!hasPupils) { %>
      <div class="text-center py-5">
        <i style="font-size: 3rem;" class="bi bi-people text-muted"></i>
        <h5 class="mt-3 text-muted">No students enrolled yet.</h5>
      </div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <%
                var colNames = ['ID', 'Name', 'Email', 'Branch', 'Year', 'Action'];
                for (var cn = 0; cn < colNames.length; cn += 1) {
              %>
                <th><%= colNames[cn] %></th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% for (var r = 0; r < pupilRecords.length; r += 1) { var record = pupilRecords[r]; %>
            <tr>
              <td>#<%= record.id %></td>
              <td class="fw-bold"><%= record.name %></td>
              <td><%= record.email %></td>
              <td><%= record.branch %></td>
              <td><span class="badge bg-secondary"><%= record.year %></span></td>
              <td>
                <form
                  method="POST"
                  action="/delete_student/<%= record.id %>"
                  onsubmit="return confirm('Remove this student and all associated applications?');"
                >
                  <button
                    class="btn btn-sm btn-outline-danger"
                    type="submit"
                    title="Remove Student"
                  >
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</div>
