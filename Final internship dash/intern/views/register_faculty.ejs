<div class="row justify-content-center mt-5">
  <div class="col-md-6">
    <div class="card shadow">
      <div class="card-header bg-info text-white text-center">
        <h4>Create Faculty Account</h4>
      </div>
      <div class="card-body">
        <form method="POST" action="/register/faculty">
          <%
            var professorInputs = [
              { caption: 'Full Name', key: 'name', kind: 'text', hint: '' },
              { caption: 'Email', key: 'email', kind: 'email', hint: '' },
              { caption: 'Password', key: 'password', kind: 'password', hint: '' },
              { caption: 'Department', key: 'department', kind: 'text', hint: 'e.g. Computer Science' }
            ];
            for (var p = 0; p < professorInputs.length; p += 1) {
              var spec = professorInputs[p];
          %>
          <div class="mb-3">
            <label class="form-label"><%= spec.caption %></label>
            <input
              class="form-control"
              name="<%= spec.key %>"
              type="<%= spec.kind %>"
              <% if (spec.hint.length > 0) { %>placeholder="<%= spec.hint %>"<% } %>
              required
            >
          </div>
          <% } %>
          <button type="submit" class="btn btn-info w-100 text-white">Create Account</button>
        </form>
        <div class="mt-3 text-center">
          <a href="/login">Already registered? Sign in here</a>
        </div>
      </div>
    </div>
  </div>
</div>
