<!DOCTYPE html>
<html
  lang="en"
>
<head>
  <meta charset="UTF-8">
  <meta
    content="width=device-width, initial-scale=1.0"
    name="viewport"
  >
  <title>Internship Portal</title>

  <!-- External stylesheets for UI framework and icons -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
    rel="stylesheet"
  >
  <!-- Project-specific overrides -->
  <link
    rel="stylesheet"
    href="/static/css/style.css"
  >

  <!-- Charting library loaded globally -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

  <!-- Primary Navigation -->
  <nav class="main-navigation-bar navbar-expand-lg sticky-top navbar">
    <div class="container">
      <a class="navbar-brand" href="/">
        <img src="/static/assets/logo.png" alt="College Logo" class="college-logo-nav">
        Internship Portal
      </a>
      <button
        type="button"
        class="navbar-toggler"
        data-bs-target="#topNavCollapse"
        data-bs-toggle="collapse"
      >
        <span class="navbar-toggler-icon"></span>
      </button>
      <div
        class="collapse navbar-collapse"
        id="topNavCollapse"
      >
        <ul class="navbar-nav ms-auto">
          <%
            var currentPath = '';
            if (locals.request) { currentPath = locals.request.path; }
            var loggedIn = (locals.user !== null && locals.user !== undefined);
            var viewerIsInstructor = loggedIn && (locals.user.role === 'faculty');
          %>
          <li class="nav-item">
            <a
              class="nav-link <% if (currentPath === '/') { %>active<% } %>"
              href="/"
            >
              <i class="bi bi-house-door me-1"></i>Home
            </a>
          </li>
          <% if (loggedIn && viewerIsInstructor) { %>
            <li class="nav-item">
              <a
                class="nav-link <% if (currentPath === '/applications') { %>active<% } %>"
                href="/applications"
              >
                <i class="bi bi-card-list me-1"></i>Applications
              </a>
            </li>
            <li class="nav-item">
              <a
                class="nav-link <% if (currentPath === '/dashboard') { %>active<% } %>"
                href="/dashboard"
              >
                <i class="bi bi-graph-up me-1"></i>Dashboard
              </a>
            </li>
            <li class="nav-item">
              <a
                class="nav-link <% if (currentPath === '/post') { %>active<% } %>"
                href="/post"
              >
                <i class="bi bi-plus-square me-1"></i>Post Internship
              </a>
            </li>
          <% } %>
          <% if (loggedIn) { %>
            <li class="nav-item ms-lg-3">
              <a
                class="nav-link btn btn-outline-danger px-3 py-1 mt-1 text-danger border-danger"
                href="/logout"
              >
                <i class="bi bi-box-arrow-right me-1"></i>Logout (<%= locals.user.name %>)
              </a>
            </li>
          <% } else { %>
            <li class="nav-item ms-lg-3">
              <a
                class="nav-link btn btn-primary text-white px-3 py-1 mt-1"
                href="/login"
              >
                <i class="bi bi-box-arrow-in-right me-1"></i>Login
              </a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Page Content Wrapper -->
  <div class="container mt-4 mb-5 entry-animation">
    <%
      var showSuccess = (locals.successMsg !== null && locals.successMsg !== undefined);
      var showError = (locals.errorMsg !== null && locals.errorMsg !== undefined);
      var showWarning = (locals.warningMsg !== null && locals.warningMsg !== undefined);
    %>
    <% if (showSuccess) { %>
      <div class="alert alert-success mt-2"><%= locals.successMsg %></div>
    <% } %>
    <% if (showError) { %>
      <div class="alert alert-danger mt-2"><%= locals.errorMsg %></div>
    <% } %>
    <% if (showWarning) { %>
      <div class="alert alert-warning mt-2"><%= locals.warningMsg %></div>
    <% } %>

    <%- body %>
  </div>

  <!-- Bootstrap runtime bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
