<div class="listing-header">
  <h2 class="section-heading">Submitted Applications</h2>
  <a
    href="/report"
    class="btn btn-primary"
  ><i class="bi bi-download me-2"></i>Download Report</a>
</div>

<div class="card p-4">
  <%
    var appList = (applications !== null && applications !== undefined) ? applications : [];
    var hasApps = (appList.length > 0);
  %>
  <% if (!hasApps) { %>
  <div class="text-center py-5">
    <i
      class="bi bi-inbox text-muted"
      style="font-size: 3rem;"
    ></i>
    <h5 class="mt-3 text-muted">No submissions to display.</h5>
  </div>
  <% } else { %>
  <div class="table-responsive">
    <table class="table table-hover">
      <thead>
        <tr>
          <%
            var colHeaders = ['ID', 'Student', 'Branch', 'Semester', 'Company', 'Duration', 'Resume', 'Status', 'Action'];
            var hi = 0;
            while (hi < colHeaders.length) {
          %>
            <th><%= colHeaders[hi] %></th>
          <% hi = hi + 1; } %>
        </tr>
      </thead>
      <tbody>
        <%
          var ai = 0;
          while (ai < appList.length) {
            var rec = appList[ai];
            var lcStatus = rec.status.toLowerCase();
        %>
        <tr>
          <td>#<%= rec.id %></td>
          <td><%= rec.student_name %></td>
          <td><%= rec.branch %></td>
          <td><span class="badge bg-secondary"><%= rec.semester %></span></td>
          <td><%= rec.company_name %></td>
          <td><%= rec.duration %></td>
          <td>
            <a
              href="/<%= rec.resume %>"
              target="_blank"
              class="btn btn-sm btn-outline-primary"
            >
              <i class="bi bi-file-earmark-text"></i> View
            </a>
          </td>
          <td>
            <% if (lcStatus === 'applied') { %>
              <span class="badge bg-warning text-dark">Applied</span>
            <% } else if (lcStatus === 'completed') { %>
              <span class="badge bg-success">Completed</span>
            <% } else { %>
              <span class="badge bg-secondary"><%= rec.status %></span>
            <% } %>
          </td>
          <td>
            <form
              action="/applications/<%= rec.id %>/update_status"
              method="POST"
              class="d-flex align-items-center gap-2"
            >
              <select
                name="status"
                class="form-select form-select-sm"
                style="width: 140px;"
              >
                <%
                  var stOpts = ['Applied', 'In Progress', 'Completed', 'Rejected'];
                  var si = 0;
                  while (si < stOpts.length) {
                    var sv = stOpts[si];
                %>
                  <option
                    value="<%= sv %>"
                    <% if (rec.status === sv) { %>selected<% } %>
                  ><%= sv %></option>
                <% si = si + 1; } %>
              </select>
              <button
                type="submit"
                class="btn btn-sm btn-success"
              >Save</button>
            </form>
          </td>
        </tr>
        <% ai = ai + 1; } %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>
