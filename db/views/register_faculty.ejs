<div class="row justify-content-center mt-5">
  <div class="col-md-6">
    <div class="card shadow">
      <div class="card-header bg-info text-white text-center">
        <h4>Create Faculty Account</h4>
      </div>
      <div class="card-body">
        <form
          action="/register/faculty"
          method="POST"
        >
          <%
            var facFields = [
              { lbl: 'Full Name', nm: 'name', tp: 'text', ph: '' },
              { lbl: 'Email', nm: 'email', tp: 'email', ph: '' },
              { lbl: 'Password', nm: 'password', tp: 'password', ph: '' },
              { lbl: 'Department', nm: 'department', tp: 'text', ph: 'e.g. Computer Science' }
            ];
            var fi = 0;
            while (fi < facFields.length) {
              var ff = facFields[fi];
          %>
          <div class="mb-3">
            <label class="form-label"><%= ff.lbl %></label>
            <input
              name="<%= ff.nm %>"
              type="<%= ff.tp %>"
              class="form-control"
              <% if (ff.ph.length > 0) { %>placeholder="<%= ff.ph %>"<% } %>
              required
            >
          </div>
          <% fi = fi + 1; } %>
          <button
            type="submit"
            class="btn btn-info w-100 text-white"
          >Create Account</button>
        </form>
        <div class="mt-3 text-center">
          <a href="/login">Already registered? Sign in here</a>
        </div>
      </div>
    </div>
  </div>
</div>
