<div class="page-header">
    <h2 class="page-title">Internship Applications</h2>
    <a href="/report" class="btn btn-primary"><i class="bi bi-download me-2"></i>Download Report</a>
</div>

<div class="card p-4">
    <% if (applications && applications.length > 0) { %>
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Student</th>
                    <th>Branch</th>
                    <th>Year</th>
                    <th>Company</th>
                    <th>Offer Letter</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% for(let app of applications) { %>
                <tr>
                    <td>#<%= app.id %></td>
                    <td><%= app.student_name %></td>
                    <td><%= app.branch %></td>
                    <td><span class="badge bg-secondary"><%= app.year %></span></td>
                    <td><%= app.company %></td>
                    <td>
                        <a href="/<%= app.offer_letter %>" target="_blank" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-file-earmark-text"></i> View
                        </a>
                    </td>
                    <td>
                        <% if (app.status.toLowerCase() == 'applied') { %>
                            <span class="badge bg-warning text-dark">Applied</span>
                        <% } else if (app.status.toLowerCase() == 'completed') { %>
                            <span class="badge bg-success">Completed</span>
                        <% } else { %>
                            <span class="badge bg-secondary"><%= app.status %></span>
                        <% } %>
                    </td>
                    <td>
                        <form action="/applications/<%= app.id %>/update_status" method="POST" class="d-flex align-items-center gap-2">
                            <select name="status" class="form-select form-select-sm" style="width: 140px;">
                                <option value="Applied" <% if (app.status == 'Applied') { %>selected<% } %>>Applied</option>
                                <option value="In Progress" <% if (app.status == 'In Progress') { %>selected<% } %>>In Progress</option>
                                <option value="Completed" <% if (app.status == 'Completed') { %>selected<% } %>>Completed</option>
                                <option value="Rejected" <% if (app.status == 'Rejected') { %>selected<% } %>>Rejected</option>
                            </select>
                            <button type="submit" class="btn btn-sm btn-success">Update</button>
                        </form>
                    </td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>
    <% } else { %>
    <div class="text-center py-5">
        <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
        <h5 class="mt-3 text-muted">No applications found.</h5>
    </div>
    <% } %>
</div>
