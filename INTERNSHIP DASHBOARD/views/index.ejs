<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <h2 class="page-title mb-0">Available Internships</h2>
    <% if (locals.user && locals.user.role === 'faculty') { %>
        <a href="/post" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Post Internship</a>
    <% } %>
</div>

<div class="row g-4">
    <% if (internships.length > 0) { %>
        <% for(let internship of internships) { %>
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 p-4 d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h4 class="mb-0 fw-bold text-truncate" title="<%= internship.company_name %>"><%= internship.company_name %></h4>
                    <% if (internship.paid_or_unpaid.toLowerCase() === 'paid') { %>
                        <span class="badge bg-success-subtle border border-success-subtle text-success-emphasis rounded-pill">Paid</span>
                    <% } else { %>
                        <span class="badge bg-danger-subtle border border-danger-subtle text-danger-emphasis rounded-pill">Unpaid</span>
                    <% } %>
                </div>
                
                <p class="text-muted mb-4 small"><i class="bi bi-briefcase me-1"></i>Domain: <%= internship.domain %></p>
                
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Eligibility</span>
                        <span class="fw-medium small"><%= internship.eligibility %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Duration</span>
                        <span class="fw-medium small"><%= internship.duration %></span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small">Mode</span>
                        <span class="fw-medium small"><%= internship.internship_mode %></span>
                    </div>
                </div>
                
                <div class="mt-auto">
                    <hr class="my-3">
                    <% if (locals.user && locals.user.role === 'student') { %>
                        <form action="/apply/<%= internship.id %>" method="POST" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label class="form-label small">Resume (PDF Only)</label>
                                <input type="file" name="resume" class="form-control form-control-sm" accept="application/pdf" required>
                            </div>
                            <button class="btn btn-primary btn-sm w-100">Apply Now</button>
                        </form>
                    <% } else if (locals.user && locals.user.role === 'faculty') { %>
                        <p class="text-muted text-center small mb-0">Students can apply to this internship.</p>
                    <% } else { %>
                        <a href="/login" class="btn btn-outline-primary btn-sm w-100">Login to Apply</a>
                    <% } %>
                </div>
            </div>
        </div>
        <% } %>
    <% } else { %>
        <div class="col-12 py-5 text-center">
            <i class="bi bi-briefcase text-muted mb-3" style="font-size: 3rem;"></i>
            <h4 class="text-muted">No Internships Available</h4>
            <% if (locals.user && locals.user.role === 'faculty') { %>
                <p class="text-muted">Check back later or <a href="/post">post a new one</a>.</p>
            <% } else if (locals.user && locals.user.role === 'student') { %>
                <p class="text-muted">Check back later when faculty post new internships!</p>
            <% } else { %>
                <p class="text-muted mb-3">Login to view or post internships!</p>
                <a href="/login" class="btn btn-primary">Login Now</a>
            <% } %>
        </div>
    <% } %>
</div>
