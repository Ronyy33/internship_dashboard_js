<%
  /* Compute role flags for conditional rendering */
  var userPresent = (locals.user !== null && locals.user !== undefined);
  var viewerIsInstructor = userPresent && (locals.user.role === 'faculty');
  var viewerIsLearner = userPresent && (locals.user.role === 'student');

  /* Ensure the internships array is safe to iterate */
  var positionList = (typeof internships !== 'undefined' && internships) ? internships : [];
  var positionCount = positionList.length;
  var noPositions = (positionCount === 0);
%>

<div class="listing-header d-flex justify-content-between align-items-center mb-4">
  <h2 class="section-heading mb-0">Available Internships</h2>
  <% if (viewerIsInstructor) { %>
    <a
      href="/post"
      class="btn btn-primary"
    ><i class="bi bi-plus-circle me-1"></i>Post Internship</a>
  <% } %>
</div>

<div class="row g-4">
  <% if (noPositions) { %>
    <div class="col-12 py-5 text-center">
      <i
        class="bi bi-briefcase text-muted mb-3"
        style="font-size: 3rem;"
      ></i>
      <h4 class="text-muted">No Internships Available</h4>
      <% if (viewerIsInstructor) { %>
        <p class="text-muted">
          Nothing here yet — <a href="/post">create a new listing</a>.
        </p>
      <% } else if (viewerIsLearner) { %>
        <p class="text-muted">
          Internships will appear here once faculty post them.
        </p>
      <% } else { %>
        <p class="text-muted mb-3">
          Sign in to browse or post internship opportunities!
        </p>
        <a
          href="/login"
          class="btn btn-primary"
        >Login Now</a>
      <% } %>
    </div>
  <% } else { %>
    <%
      var pi = 0;
      while (pi < positionCount) {
        var pos = positionList[pi];
        var compensation = pos.paid_or_unpaid.toLowerCase();
        var isPaid = (compensation === 'paid');
    %>
    <div class="col-md-4 mb-4">
      <div class="card internship-card h-100">
        <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-3">
          <h4
            class="mb-0 fw-bold text-truncate"
            title="<%= pos.company_name %>"
          ><%= pos.company_name %></h4>
          <% if (isPaid) { %>
            <span
              class="badge bg-success-subtle border border-success-subtle text-success-emphasis rounded-pill"
            >Paid</span>
          <% } else { %>
            <span
              class="badge bg-danger-subtle border border-danger-subtle text-danger-emphasis rounded-pill"
            >Unpaid</span>
          <% } %>
        </div>

        <p class="text-muted mb-4 small">
          <i class="bi bi-briefcase me-1"></i>Domain: <%= pos.domain %>
        </p>

        <div class="mb-4">
          <%
            var detailPairs = [
              { label: 'Eligibility', val: pos.eligibility },
              { label: 'Duration', val: pos.duration },
              { label: 'Mode', val: pos.internship_mode }
            ];
            var di = 0;
            while (di < detailPairs.length) {
              var dp = detailPairs[di];
          %>
          <div class="d-flex justify-content-between<%= (di < detailPairs.length - 1) ? ' mb-2' : '' %>">
            <span class="text-muted small"><%= dp.label %></span>
            <span class="fw-medium small"><%= dp.val %></span>
          </div>
          <% di = di + 1; } %>
        </div>

        <div class="mt-auto">
          <hr class="my-3">
          <% if (viewerIsLearner) { %>
            <form
              enctype="multipart/form-data"
              method="POST"
              action="/apply/<%= pos.id %>"
            >
              <div class="mb-3">
                <label class="form-label small">Resume (PDF Only)</label>
                <input
                  type="file"
                  name="resume"
                  accept="application/pdf"
                  class="form-control form-control-sm"
                  required
                >
              </div>
              <button class="btn btn-primary btn-sm w-100">Apply Now</button>
            </form>
          <% } else if (viewerIsInstructor) { %>
            <p class="text-muted text-center small mb-0">
              Students can submit applications for this listing.
            </p>
          <% } else { %>
            <a
              href="/login"
              class="btn btn-outline-primary btn-sm w-100"
            >Login to Apply</a>
          <% } %>
        </div>
      </div>
    </div>
    </div>
    <% pi = pi + 1; } %>
  <% } %>
</div>

