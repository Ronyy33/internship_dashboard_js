<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Internship Portal</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/static/css/style.css">
    
    <!-- Chart.js (Loaded only when needed but generally safe to include in head) -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="bi bi-briefcase-fill me-2"></i>Internship Portal
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link <% if (locals.request && locals.request.path === '/') { %>active<% } %>" href="/">
                            <i class="bi bi-house-door me-1"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <% if (locals.request && locals.request.path === '/applications') { %>active<% } %>" href="/applications">
                            <i class="bi bi-card-list me-1"></i>Applications
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <% if (locals.request && locals.request.path === '/dashboard') { %>active<% } %>" href="/dashboard">
                            <i class="bi bi-graph-up me-1"></i>Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <% if (locals.request && locals.request.path === '/post') { %>active<% } %>" href="/post">
                            <i class="bi bi-plus-square me-1"></i>Post Internship
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <% if (locals.request && locals.request.path === '/add_student') { %>active<% } %>" href="/add_student">
                            <i class="bi bi-person-plus me-1"></i>Add Student
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content Context -->
    <div class="container mt-4 mb-5 fade-in">
        <% if (locals.successMsg) { %>
            <div class="alert alert-success mt-2"><%= locals.successMsg %></div>
        <% } %>
        <% if (locals.errorMsg) { %>
            <div class="alert alert-danger mt-2"><%= locals.errorMsg %></div>
        <% } %>
        <% if (locals.warningMsg) { %>
            <div class="alert alert-warning mt-2"><%= locals.warningMsg %></div>
        <% } %>

        <%- body %>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    
</body>
</html>
