<div class="row justify-content-center mb-5">
  <div class="col-md-8">
    <div class="listing-header d-flex justify-content-between align-items-center mb-4">
      <h2 class="section-heading mb-0">Enroll a New Student</h2>
    </div>

    <div class="card p-4">
      <form
        action="/add_student"
        method="POST"
      >
        <div class="row mb-3">
          <%
            var enrollFields = [
              { lbl: 'Full Name', nm: 'name', tp: 'text', ph: 'John Doe' },
              { lbl: 'Email Address', nm: 'email', tp: 'email', ph: 'john@example.com' }
            ];
            var efi = 0;
            while (efi < enrollFields.length) {
              var ef = enrollFields[efi];
          %>
          <div class="col-md-6">
            <label><%= ef.lbl %></label>
            <input
              type="<%= ef.tp %>"
              name="<%= ef.nm %>"
              placeholder="<%= ef.ph %>"
              class="form-control"
              required
            >
          </div>
          <% efi = efi + 1; } %>
        </div>

        <div class="row mb-4">
          <div class="col-md-6">
            <label>Branch</label>
            <input
              type="text"
              name="branch"
              placeholder="e.g. Computer Science"
              class="form-control"
              required
            >
          </div>
          <div class="col-md-6">
            <label>Year</label>
            <select
              name="year"
              class="form-select"
            >
              <%
                var yearOpts = [
                  { val: 'SE', display: 'SE (Second Year)' },
                  { val: 'TE', display: 'TE (Third Year)' },
                  { val: 'BE', display: 'BE (Final Year)' }
                ];
                var yi = 0;
                while (yi < yearOpts.length) {
                  var yo = yearOpts[yi];
              %>
                <option value="<%= yo.val %>"><%= yo.display %></option>
              <% yi = yi + 1; } %>
            </select>
          </div>
        </div>

        <button
          type="submit"
          class="btn btn-primary w-100"
        >
          <i class="bi bi-person-plus me-2"></i>Enroll Student
        </button>
      </form>
    </div>
  </div>
</div>

<div class="row justify-content-center">
  <div class="col-md-10">
    <h4 class="mb-4">Enrolled Students</h4>
    <div class="card p-4">
      <%
        var stuList = (students !== null && students !== undefined) ? students : [];
        var hasStu = (stuList.length > 0);
      %>
      <% if (!hasStu) { %>
      <div class="text-center py-5">
        <i
          class="bi bi-people text-muted"
          style="font-size: 3rem;"
        ></i>
        <h5 class="mt-3 text-muted">No students enrolled yet.</h5>
      </div>
      <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <%
                var stuCols = ['ID', 'Name', 'Email', 'Branch', 'Year', 'Action'];
                var sci = 0;
                while (sci < stuCols.length) {
              %>
                <th><%= stuCols[sci] %></th>
              <% sci = sci + 1; } %>
            </tr>
          </thead>
          <tbody>
            <% var li = 0; while (li < stuList.length) { var stu = stuList[li]; %>
            <tr>
              <td>#<%= stu.id %></td>
              <td class="fw-bold"><%= stu.name %></td>
              <td><%= stu.email %></td>
              <td><%= stu.branch %></td>
              <td><span class="badge bg-secondary"><%= stu.year %></span></td>
              <td>
                <form
                  action="/delete_student/<%= stu.id %>"
                  method="POST"
                  onsubmit="return confirm('Remove this student and all associated applications?');"
                >
                  <button
                    type="submit"
                    title="Remove Student"
                    class="btn btn-sm btn-outline-danger"
                  >
                    <i class="bi bi-trash"></i>
                  </button>
                </form>
              </td>
            </tr>
            <% li = li + 1; } %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>
</div>
